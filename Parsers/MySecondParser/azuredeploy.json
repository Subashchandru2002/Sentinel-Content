{
 "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
 "contentVersion": "1.0.0.0",
 "parameters": {
   "workspace": {
     "type": "string"
   }
 },
 "resources": [
   {
     "type": "Microsoft.OperationalInsights/workspaces/savedSearches",
     "apiVersion": "2020-08-01",
     "name": "[concat(parameters('workspace'), '/MySecondParser')]",
     "properties": {
       "displayName": "MySecondParser",
       "category": "Parsers",
       "query": "CommonSecurityLog | extend ParsedStatus=tostring(DeviceEventClassID)",
       "functionAlias": "MySecondParser",
       "version": 1
     }
   }
 ]
}
